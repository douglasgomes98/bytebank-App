rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers de validação de schema ----
    function isAuthed() {
      return request.auth != null;
    }

    function nonEmptyString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function isOptionalString(data, key, maxLen) {
      return !(key in data) || data[key] == null
        || (data[key] is string && data[key].size() <= maxLen);
    }

    function isUserPayload(data) {
      return data.keys().hasOnly(['name', 'email', 'avatarUrl', 'balance', 'createdAt'])
        && nonEmptyString(data.name, 100)
        && nonEmptyString(data.email, 254)
        && data.balance is number && data.balance >= 0
        && data.createdAt is timestamp
        && isOptionalString(data, 'avatarUrl', 2048);
    }

    function isTransactionPayload(data) {
      return data.keys().hasOnly([
          'userId', 'description', 'amount', 'type', 'category',
          'date', 'receiptUrl', 'notes', 'createdAt'
        ])
        && data.userId is string
        && nonEmptyString(data.description, 200)
        && data.amount is number
        && data.amount > 0
        && data.amount <= 1000000
        && data.type in ['income', 'expense', 'transfer']
        && data.category is string && data.category.size() <= 64
        && data.date is timestamp
        && data.createdAt is timestamp
        && isOptionalString(data, 'receiptUrl', 2048)
        && isOptionalString(data, 'notes', 500);
    }

    // ---- Users ----
    match /users/{userId} {
      allow read: if isAuthed() && request.auth.uid == userId;

      allow create: if isAuthed()
        && request.auth.uid == userId
        && isUserPayload(request.resource.data);

      allow update: if isAuthed()
        && request.auth.uid == userId
        && resource.data.createdAt == request.resource.data.createdAt
        && isUserPayload(request.resource.data);

      allow delete: if isAuthed() && request.auth.uid == userId;
    }

    // ---- Transactions ----
    match /transactions/{transactionId} {
      allow read: if isAuthed()
        && request.auth.uid == resource.data.userId;

      allow create: if isAuthed()
        && request.auth.uid == request.resource.data.userId
        && isTransactionPayload(request.resource.data);

      allow update: if isAuthed()
        && request.auth.uid == resource.data.userId
        && request.auth.uid == request.resource.data.userId
        && resource.data.userId == request.resource.data.userId
        && resource.data.createdAt == request.resource.data.createdAt
        && isTransactionPayload(request.resource.data);

      allow delete: if isAuthed()
        && request.auth.uid == resource.data.userId;
    }
  }
}
